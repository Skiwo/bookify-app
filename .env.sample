# POP credentials are optional as env vars — each booker enters their own in Settings.
# Set these only if you want a server-wide fallback for all users.
# POP_API_KEY=your-sandbox-api-key
# POP_HMAC_SECRET=your-sandbox-hmac-secret
# POP_BASE_URL=https://sandbox.core.payoutpartner.com
# POP_PARTNER_ID=your-partner-uuid
DATABASE_URL=postgres://localhost/bookify_development
SECRET_KEY_BASE=generate-with-rails-secret
AWS_SES_USER=your-ses-smtp-user
AWS_SES_PASSWORD=your-ses-smtp-password
AWS_SES_REGION=eu-west-1
SMTP_DOMAIN=bookify.app
MAILER_FROM=no-reply@mail.bookify.app
