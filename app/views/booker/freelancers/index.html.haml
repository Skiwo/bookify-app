.d-flex.justify-content-between.align-items-center.mb-4
  %h2 Freelancers
  - if pop_configured?
    %a.btn.btn-primary{href: new_booker_freelancer_path}
      %i.bi.bi-plus-lg.me-1
      Invite Freelancer

- if @engagements.any?
  .table-responsive
    %table.table.table-hover.align-middle
      %thead.table-light
        %tr
          %th Name
          %th Email
          %th Status
          %th
      %tbody
        - @engagements.each do |eng|
          %tr
            %td
              %a.fw-medium.text-decoration-none{href: booker_freelancer_path(eng)}= eng.name
            %td.text-muted= eng.email
            %td
              - case eng.status
              - when "invited"
                %span.badge.bg-warning.text-dark Invited
              - when "onboarding"
                %span.badge.bg-info Onboarding
              - when "active"
                %span.badge.bg-success Active
              - when "removed"
                %span.badge.bg-secondary Removed
            %td.text-end
              = link_to "View", booker_freelancer_path(eng), class: "btn btn-sm btn-outline-primary"
  = paginate @engagements
- else
  .card.border-0.shadow-sm.text-center.py-5
    .card-body
      %i.bi.bi-people.display-3.text-muted
      %h5.fw-bold.mt-3 No freelancers yet
      - if pop_configured?
        %p.text-muted Invite your first freelancer to get started.
        %a.btn.btn-primary{href: new_booker_freelancer_path}
          %i.bi.bi-plus-lg.me-1
          Invite Freelancer
      - else
        %p.text-muted.mb-3 Connect your POP account to start inviting freelancers.
        %a.btn.btn-outline-primary{href: booker_settings_path}
          %i.bi.bi-gear.me-1
          Go to Settings
