- unless pop_configured?
  .alert.alert-warning.d-flex.align-items-start.mb-4
    %i.bi.bi-exclamation-triangle-fill.me-3.mt-1.fs-5
    %div
      %strong Connect your Payout Partner account to get started.
      %p.mb-1 Add your POP API credentials so you can invite freelancers, create bookings, and process payouts.
      %a.btn.btn-warning.btn-sm.mt-1{href: booker_settings_path}
        %i.bi.bi-gear.me-1
        Go to Settings

= render "shared/welcome_guide"

%h2.mb-4
  Dashboard
  - if current_user.name.present?
    %small.text-muted.fw-normal= "— #{current_user.name}"

- if @freelancer_count == 0 && @recent_bookings.empty?
  .card.border-0.shadow-sm.text-center.py-5
    .card-body
      %i.bi.bi-people.display-3.text-muted.mb-3
      %h4.fw-bold Get started by inviting a freelancer
      %p.text-muted.mb-4 Invite someone by email — they'll verify their identity through POP and you can start paying them.
      - if pop_configured?
        %a.btn.btn-primary.btn-lg{href: new_booker_freelancer_path}
          %i.bi.bi-plus-lg.me-2
          Invite Your First Freelancer
      - else
        %a.btn.btn-outline-primary{href: booker_settings_path}
          %i.bi.bi-gear.me-1
          Connect POP first

- else
  .row
    .col-md-4.mb-3
      .card.shadow-sm.border-0.sidebar-tint
        .card-body.text-center.py-3
          %h3.text-primary.fw-bold.mb-0= @freelancer_count
          %p.text-muted.small.mb-0 Active Freelancers
    .col-md-4.mb-3
      .card.shadow-sm.border-0.sidebar-tint
        .card-body.text-center.py-3
          %h3.text-primary.fw-bold.mb-0= @completed_unpaid
          %p.text-muted.small.mb-0 Ready to Pay
    .col-md-4.mb-3
      .card.shadow-sm.border-0.sidebar-tint
        .card-body.text-center.py-3
          %h3.text-primary.fw-bold.mb-0= @total_payouts
          %p.text-muted.small.mb-0 Total Payouts

  .row.mt-4
    .col-md-6
      .card.border-0.shadow-sm
        .card-header.bg-white.fw-bold Recent Bookings
        .card-body
          - if @recent_bookings.any?
            .list-group.list-group-flush
              - @recent_bookings.each do |booking|
                = link_to booker_booking_path(booking), class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center" do
                  %div
                    %span.fw-medium= booking.description
                    %br
                    %small.text-muted= booking.engagement.name
                  %span.badge.bg-primary.rounded-pill= booking.status.humanize
          - else
            %p.text-muted.mb-0.py-2 No bookings yet.
            - if pop_configured?
              %a.small{href: new_booker_booking_path} Create your first booking

    .col-md-6
      .card.border-0.shadow-sm
        .card-header.bg-white.fw-bold Recent Payouts
        .card-body
          - if @recent_payouts.any?
            .list-group.list-group-flush
              - @recent_payouts.each do |payout|
                = link_to booker_payout_path(payout), class: "list-group-item list-group-item-action d-flex justify-content-between align-items-center" do
                  %div
                    %span.fw-medium= payout.pop_invoice_number || payout.id.first(8)
                    %br
                    %small.text-muted= format_nok(payout.amount_ore)
                  %span.badge.bg-secondary.rounded-pill= payout.pop_status || "pending"
          - else
            %p.text-muted.mb-0.py-2 No payouts yet.
