.d-flex.justify-content-between.align-items-center.mb-4
  %h2 Bookings
  %a.btn.btn-primary{href: new_booker_booking_path}
    %i.bi.bi-plus-lg.me-1
    New Booking

- if @bookings.any?
  .table-responsive
    %table.table.table-hover.align-middle
      %thead.table-light
        %tr
          %th Description
          %th Freelancer
          %th Rate
          %th Hours
          %th Total
          %th Status
      %tbody
        - @bookings.each do |booking|
          %tr
            %td= link_to booking.description, booker_booking_path(booking), class: "fw-medium text-decoration-none"
            %td.text-muted= booking.enrollment.name
            %td= format_nok_value(booking.rate_nok)
            %td= booking.hours
            %td.fw-bold= format_nok_value(booking.total_nok)
            %td
              %span.badge{class: booking.has_payout? ? "bg-success" : booking.completed? ? "bg-primary" : "bg-secondary"}= booking.status.humanize
  = paginate @bookings
- else
  .card.border-0.shadow-sm.text-center.py-5
    .card-body
      %i.bi.bi-calendar-check.display-3.text-muted
      %h5.fw-bold.mt-3 No bookings yet
      %p.text-muted Create a booking to log work and pay a freelancer.
      %a.btn.btn-primary{href: new_booker_booking_path}
        %i.bi.bi-plus-lg.me-1
        New Booking
