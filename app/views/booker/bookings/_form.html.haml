= form_for @booking, url: form_url, html: { data: { controller: "booking-form" } } do |f|
  - if @booking.errors.any?
    .alert.alert-danger.mb-3
      - @booking.errors.full_messages.each do |msg|
        %p.mb-0= msg

  -# === Invoice-level fields ===

  - if @enrollments
    .mb-3
      = f.label :enrollment_id, "Freelancer", class: "form-label"
      = f.select :enrollment_id, @enrollments.map { |e| [e.name, e.id] }, { prompt: "Select freelancer" }, class: "form-select", required: true

  .mb-3
    = f.label :description, "Booking title (optional)", class: "form-label"
    = f.text_field :description, class: "form-control", placeholder: "e.g. March 2026 work"

  .mb-3.border.rounded.p-3.bg-light
    %h6.text-muted.mb-2 Invoice details
    .row
      .col-md-6.mb-3
        = f.label :order_reference, "Order reference", class: "form-label"
        = f.text_field :order_reference, class: "form-control", placeholder: "e.g. PO-2026-042"
      .col-md-6.mb-3
        = f.label :buyer_reference, "Buyer reference", class: "form-label"
        = f.text_field :buyer_reference, class: "form-control", placeholder: "Optional; defaults on POP if omitted"
    .row
      .col-md-6.mb-3
        = f.label :invoiced_on, "Invoiced on", class: "form-label"
        = f.date_field :invoiced_on, class: "form-control"
        %small.text-muted If blank, uses first line's work date or today.
      .col-md-6.mb-3
        = f.label :due_on, "Due on", class: "form-label"
        = f.date_field :due_on, class: "form-control"
        %small.text-muted If blank, POP defaults (e.g. invoiced + 14 days).
    .mb-0
      = f.label :external_note, "External note (invoice memo)", class: "form-label"
      = f.text_area :external_note, class: "form-control", rows: 2, placeholder: "Optional note on the invoice"

  %hr.my-4

  -# === Booking lines ===

  %h5.mb-3 Lines

  %div{"data-booking-form-target": "lineContainer"}
    = f.fields_for :booking_lines do |lf|
      = render "line_fields", lf: lf, idx: lf.index, occupation_codes: @occupation_codes, occupation_codes_error: @occupation_codes_error

  %template{"data-booking-form-target": "lineTemplate"}
    = f.fields_for :booking_lines, BookingLine.new, child_index: "NEW_RECORD" do |lf|
      = render "line_fields", lf: lf, idx: "NEW_RECORD", occupation_codes: @occupation_codes, occupation_codes_error: @occupation_codes_error

  .mb-3
    %button.btn.btn-outline-secondary.w-100{type: "button", "data-action": "click->booking-form#addLine"}
      %i.bi.bi-plus-lg.me-1
      Add Line

  -# === Grand total ===

  .mb-3
    .card.border-0{"style": "background-color: #f0f4ff"}
      .card-body.py-2.px-3.d-flex.justify-content-between
        %span.fw-bold Grand total
        %strong.fs-5{"data-booking-form-target": "grandTotal"} kr 0.00

  = f.submit (@booking.new_record? ? "Create Booking" : "Update Booking"), class: "btn btn-primary w-100"
