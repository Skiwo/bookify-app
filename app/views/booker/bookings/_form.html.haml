- qty_name = @booking.project_based? ? "booking[total_hours]" : "booking[hours]"
- qty_value = @booking.project_based? ? @booking.total_hours : @booking.hours

= form_for @booking, url: form_url, html: { class: "booking-entry-form", data: { controller: "booking-entry", action: "input->booking-entry#refresh" } } do |f|
  - if @booking.errors.any?
    .alert.alert-danger
      - @booking.errors.full_messages.each do |msg|
        %div= msg

  - if @enrollments
    %div
      = f.label :enrollment_id, "Freelancer", class: "form-label"
      = f.select :enrollment_id, @enrollments.map { |e| [e.name, e.id] }, { prompt: "Select freelancer" }, class: "form-select", required: true

  %div
    = f.label :description, "Description", class: "form-label"
    = f.text_field :description, class: "form-control", required: true

  %div
    = f.label :occupation_code, "Occupation code", class: "form-label"
    - if @occupation_codes&.any?
      = f.select :occupation_code, @occupation_codes.map { |oc| ["#{oc['code']} \u2014 #{oc['name']}", oc['code']] }, { prompt: "Select code (optional)", selected: @booking.occupation_code }, class: "form-select"
    - else
      = f.text_field :occupation_code, class: "form-control"
      - if @occupation_codes_error
        .text-danger.small Could not load codes from POP.

  %div
    = f.label :order_reference, "Order reference", class: "form-label"
    = f.text_field :order_reference, class: "form-control"

  %hr

  %div
    = f.label :booking_type, "How is this work billed?", class: "form-label"
    = f.select :booking_type, [["By the hour (single day)", "time_based"], ["As a project (date range)", "project_based"]], {}, class: "form-select", data: { action: "change->booking-entry#modeChanged" }

  %div.row.g-3
    %div.col-sm-6
      %label.form-label{for: "rate_nok_input"} Amount per hour (NOK)
      .input-group
        %span.input-group-text kr
        %input.form-control{type: "number", name: "rate_nok", id: "rate_nok_input", min: 1, step: "0.01", value: (@rate_nok || @booking.rate_nok)}
    %div.col-sm-6
      %label.form-label{for: "js-booking-quantity"} Hours (quantity)
      %input.form-control{type: "number", name: qty_name, id: "js-booking-quantity", min: 0.25, step: "0.25", value: qty_value}

  %div#js-booking-time-block{ hidden: @booking.project_based? }
    %h6.mt-4.text-muted When (time-based)
    %div.mb-3
      = f.label :work_date, "Date of work", class: "form-label"
      = f.date_field :work_date, class: "form-control", value: @booking.work_date || Date.current
    %div.row.g-3
      %div.col-sm-6
        = f.label :start_time, "Start", class: "form-label"
        = f.time_field :start_time, class: "form-control"
      %div.col-sm-6
        = f.label :end_time, "End", class: "form-label"
        = f.time_field :end_time, class: "form-control"

  %div#js-booking-project-block{ hidden: !@booking.project_based? }
    %h6.mt-4.text-muted Project dates
    %div.row.g-3
      %div.col-sm-6
        = f.label :work_start_date, "First day", class: "form-label"
        = f.date_field :work_start_date, class: "form-control", value: @booking.work_start_date || Date.current
      %div.col-sm-6
        = f.label :work_end_date, "Last day", class: "form-label"
        = f.date_field :work_end_date, class: "form-control"

  %hr

  %div.d-flex.justify-content-between.align-items-baseline.border.rounded.p-3.bg-light
    %span.text-secondary Estimated total
    %span.fs-5.fw-bold{data: { booking_entry_target: "total" }} kr 0.00

  = f.submit (@booking.new_record? ? "Create Booking" : "Update Booking"), class: "btn btn-primary w-100 mt-2"
