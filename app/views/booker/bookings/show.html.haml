= render "shared/breadcrumbs", crumbs: [["Bookings", booker_bookings_path], @booking.summary]

.d-flex.justify-content-between.align-items-center.mb-4
  %h2= @booking.summary
  .d-flex.gap-2
    - if @booking.editable?
      = link_to "Edit", edit_booker_booking_path(@booking), class: "btn btn-outline-secondary btn-sm"
    - if @booking.draft?
      = button_to "Mark Completed", complete_booker_booking_path(@booking), method: :post, class: "btn btn-outline-success btn-sm"
    - if @booking.can_uncomplete?
      = button_to "Revert to Draft", uncomplete_booker_booking_path(@booking), method: :post, class: "btn btn-outline-warning btn-sm", data: { confirm: "Revert this booking to draft?" }
    - if @booking.completed? && !@booking.payout
      = button_to "Pay via POP", pay_booker_booking_path(@booking), method: :post, class: "btn btn-primary btn-sm", data: { confirm: "This will create a payout through POP and pay the freelancer. Continue?" }

.row
  .col-md-5
    .card.shadow-sm.border-0.mb-3
      .card-header.bg-white.fw-bold Invoice Details
      .card-body
        .row.mb-2
          .col-5.text-muted Freelancer
          .col-7= link_to @booking.enrollment.name, booker_freelancer_path(@booking.enrollment)
        .row.mb-2
          .col-5.text-muted Status
          .col-7
            %span.badge{class: @booking.has_payout? ? "bg-success" : @booking.completed? ? "bg-primary" : "bg-secondary"}= @booking.status.humanize
        - if @booking.order_reference.present?
          .row.mb-2
            .col-5.text-muted Order reference
            .col-7= @booking.order_reference
        - if @booking.invoiced_on.present?
          .row.mb-2
            .col-5.text-muted Invoiced on
            .col-7= @booking.invoiced_on.strftime("%b %d, %Y")
        - if @booking.due_on.present?
          .row.mb-2
            .col-5.text-muted Due on
            .col-7= @booking.due_on.strftime("%b %d, %Y")
        - if @booking.buyer_reference.present?
          .row.mb-2
            .col-5.text-muted Buyer reference
            .col-7= @booking.buyer_reference
        - if @booking.external_note.present?
          .row.mb-2
            .col-5.text-muted External note
            .col-7{style: "white-space: pre-wrap"}= @booking.external_note
        .row
          .col-5.text-muted.fw-bold Total
          .col-7
            %strong= format_nok_value(@booking.total_nok)

    - if @booking.payout
      .card.shadow-sm.border-0
        .card-header.bg-white.fw-bold Payout
        .card-body
          .row.mb-2
            .col-5.text-muted Invoice
            .col-7= link_to(@booking.payout.pop_invoice_number || "View payout", booker_payout_path(@booking.payout))
          .row.mb-2
            .col-5.text-muted Status
            .col-7
              %span.badge.bg-info= @booking.payout.pop_status || "pending"
          .row
            .col-5.text-muted Amount
            .col-7
              %strong= format_nok(@booking.payout.amount_ore)

  .col-md-7
    .card.shadow-sm.border-0.mb-3
      .card-header.bg-white.fw-bold Lines
      - @booking.booking_lines.each_with_index do |line, i|
        .card-body{class: i > 0 ? "border-top" : nil}
          .d-flex.justify-content-between.align-items-start.mb-2
            %h6.mb-0= line.description
            %span.badge.bg-light.text-dark= line.booking_type.humanize
          .row.mb-2
            .col-4.text-muted Rate
            .col-8= format_nok_value(line.rate_nok)
          .row.mb-2
            .col-4.text-muted Quantity
            .col-8= line.effective_hours
          .row.mb-2
            .col-4.text-muted Line total
            .col-8
              %strong= format_nok_value(line.total_nok)
          - if line.time_based?
            .row.mb-2
              .col-4.text-muted Work date
              .col-8= line.work_date&.strftime("%b %d, %Y") || "—"
            - if line.start_time.present?
              .row.mb-2
                .col-4.text-muted Time
                .col-8= "#{line.start_time&.strftime('%H:%M')} – #{line.end_time&.strftime('%H:%M')}"
          - if line.project_based?
            .row.mb-2
              .col-4.text-muted Period
              .col-8= "#{line.work_start_date&.strftime('%b %d')} – #{line.work_end_date&.strftime('%b %d, %Y')}"
          - if line.occupation_code.present?
            .row.mb-2
              .col-4.text-muted Occupation code
              .col-8= line.occupation_code
          - if line.line_external_id.present?
            .row
              .col-4.text-muted Line external ID
              .col-8= line.line_external_id
