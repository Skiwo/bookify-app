<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body {
      margin: 0;
      padding: 0;
      background-color: #f8f9fa;
      font-family: 'Outfit', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      color: #212529;
      -webkit-font-smoothing: antialiased;
    }
    .wrapper {
      max-width: 480px;
      margin: 0 auto;
      padding: 40px 20px;
    }
    .card {
      background: #ffffff;
      border-radius: 12px;
      padding: 40px 32px;
      text-align: center;
    }
    .logo {
      font-size: 24px;
      font-weight: 700;
      color: #4f46e5;
      margin-bottom: 24px;
    }
    .logo span {
      display: inline-block;
      width: 32px;
      height: 32px;
      background: #4f46e5;
      color: #fff;
      border-radius: 8px;
      text-align: center;
      line-height: 32px;
      font-size: 18px;
      margin-right: 8px;
      vertical-align: middle;
    }
    h1 {
      font-size: 22px;
      font-weight: 700;
      margin: 0 0 8px;
    }
    .subtitle {
      color: #6c757d;
      font-size: 15px;
      margin: 0 0 28px;
    }
    .token-box {
      background: #f1f3f5;
      border-radius: 8px;
      padding: 16px;
      margin-bottom: 24px;
    }
    .token-label {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #6c757d;
      margin: 0 0 8px;
      font-weight: 600;
    }
    .token {
      font-size: 32px;
      font-weight: 700;
      letter-spacing: 0.15em;
      color: #212529;
      margin: 0;
      font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
    }
    .divider {
      border: none;
      border-top: 1px solid #e9ecef;
      margin: 24px 0;
    }
    .or-text {
      color: #6c757d;
      font-size: 13px;
      margin: 0 0 16px;
    }
    .btn {
      display: inline-block;
      background: #4f46e5;
      color: #ffffff !important;
      text-decoration: none;
      padding: 12px 32px;
      border-radius: 8px;
      font-size: 15px;
      font-weight: 600;
    }
    .footer {
      text-align: center;
      margin-top: 24px;
      color: #adb5bd;
      font-size: 13px;
    }
    .footer a {
      color: #6c757d;
      text-decoration: none;
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="card">
      <div class="logo">
        <span>B</span> Bookify
      </div>

      <h1>Sign in to Bookify</h1>
      <p class="subtitle">Enter the code below, or click the magic link.</p>

      <div class="token-box">
        <p class="token-label">Your code</p>
        <p class="token"><%= @token %></p>
      </div>

      <hr class="divider">

      <p class="or-text">Or sign in with one click:</p>

      <a href="<%= @magic_link %>" class="btn">Sign in to Bookify &rarr;</a>
    </div>

    <div class="footer">
      <p>This link expires in 15 minutes.</p>
      <p>Didn&rsquo;t request this? Just ignore this email.</p>
    </div>
  </div>
</body>
</html>
