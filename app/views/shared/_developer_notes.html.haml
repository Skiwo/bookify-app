- if pop_client&.api_calls&.any?
  .dev-overlay{id: "devOverlay", onclick: "toggleDevPanel()"}
  .dev-panel{id: "devPanel"}
    .p-3
      .d-flex.justify-content-between.align-items-center.mb-3
        %h5.mb-0
          %i.bi.bi-code-slash.me-2
          Developer Notes
        %button.btn.btn-sm.btn-outline-light{onclick: "toggleDevPanel()"} ×
      %p.text-muted.small These are the actual POP API calls made for this page.

      - pop_client.api_calls.each_with_index do |call, i|
        .card.bg-dark.border-secondary.mb-3
          .card-header.d-flex.justify-content-between.align-items-center
            %span
              %strong= call[:method]
              = call[:path]
            - status = call[:status]
            - css = status.between?(200,299) ? "status-2xx" : status.between?(400,499) ? "status-4xx" : "status-5xx"
            %span.status-badge{class: css}= "#{status}"
          .card-body
            - if call[:request_body]
              %p.text-muted.small.mb-1 Request Body:
              %pre= begin; JSON.pretty_generate(call[:request_body]); rescue JSON::GeneratorError; call[:request_body].to_s; end
            %p.text-muted.small.mb-1 Response:
            %pre= begin; JSON.pretty_generate(call[:response_body]); rescue JSON::GeneratorError; call[:response_body].to_s; end

  %button.dev-fab{onclick: "toggleDevPanel()", title: "API Calls (#{pop_client.api_calls.size})"}
    %i.bi.bi-braces

  :javascript
    function toggleDevPanel() {
      document.getElementById('devPanel').classList.toggle('open');
      document.getElementById('devOverlay').classList.toggle('open');
    }
